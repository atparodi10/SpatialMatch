<?xml version = "1.0" encoding = "ISO-8859-1"?>

<!DOCTYPE aplicacion SYSTEM "dtds/aplicacion.dtd">

<aplicacion nombre="SpatialMatch">

	<!--
Un módulo por defecto se asume para cada
controlador en <modulo-defecto/>
-->
	<modulo-defecto>
		<controlador nombre="Typical"/>
	</modulo-defecto>

	<!-- Configuración del Módulo Evaluación -->
	<modulo nombre="Evaluacion">
		<modelo nombre="Evaluacion"/>
		<!-- Le inyectamos el controlador que tiene el botón "Iniciar Prueba" -->
		<controlador nombre="EvaluacionController"/>
	</modulo>

	<!-- Configuración del Módulo para responder las preguntas -->
	<modulo nombre="RegistroRespuesta">
		<modelo nombre="RegistroRespuesta"/>
		<!-- Le inyectamos el controlador que tiene los botones "Siguiente" y "Finalizar" -->
		<controlador nombre="PruebaActivaController"/>
	</modulo>
</aplicacion>

