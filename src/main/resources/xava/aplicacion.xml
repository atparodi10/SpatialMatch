<?xml version = "1.0" encoding = "ISO-8859-1"?>

<!DOCTYPE aplicacion SYSTEM "dtds/aplicacion.dtd">

<aplicacion nombre="SpatialMatch">

	<modulo-defecto>
		<controlador nombre="Typical"/>
	</modulo-defecto>

	<!-- Modulo para gestionar Usuarios -->
	<modulo nombre="Usuario">
		<modelo nombre="Usuario"/>
		<controlador nombre="Typical"/>
	</modulo>

	<!-- Modulo para gestionar Preguntas -->
	<modulo nombre="Pregunta">
		<modelo nombre="Pregunta"/>
		<controlador nombre="Typical"/>
	</modulo>

	<!-- Modulo Evaluacion: los controladores se definen via @Controllers en la entidad -->
	<modulo nombre="Evaluacion">
		<modelo nombre="Evaluacion"/>
		<controlador nombre="Typical"/>
		<controlador nombre="EvaluacionController"/>
	</modulo>

</aplicacion>
