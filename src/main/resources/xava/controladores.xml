<?xml version = "1.0" encoding = "ISO-8859-1"?>
<!DOCTYPE controllers SYSTEM "dtds/controllers.dtd">

<controllers>

    <!-- 1. Controlador para la pantalla principal de la Evaluación -->
    <controller name="EvaluacionController">
        <!-- Heredamos de Typical para conservar los botones nativos (Nuevo, Guardar, etc.) -->
        <extends controller="Typical"/>

        <!-- Nuestro botón personalizado para arrancar -->
        <action name="iniciarPrueba"
                class="ni.edu.uam.SpatialMatch.acciones.IniciarEvaluacionAction"
                mode="detail"
                icon="play" />
    </controller>


    <!-- 2. Controlador para la pantalla donde se ven las preguntas (La Prueba Activa) -->
    <controller name="PruebaActivaController">
        <!-- NOTA: No heredamos de Typical porque aquí no queremos que el usuario
             vea el botón de "Borrar" o "Crear Nuevo". Solo queremos que responda. -->

        <!-- Botón para avanzar a la siguiente pregunta -->
        <action name="siguientePregunta"
                class="ni.edu.uam.SpatialMatch.acciones.SiguientePreguntaAction"
                mode="detail"
                icon="arrow-right" />

        <!-- Botón para forzar la finalización manual (Opcional, pero recomendado tenerlo) -->
        <action name="finalizarPrueba"
                class="ni.edu.uam.SpatialMatch.acciones.FinalizarEvaluacionAction"
                mode="detail"
                icon="stop" />
    </controller>

</controllers>